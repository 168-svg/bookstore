{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm install --omit=dev --no-audit --no-fund"
  },
  "deploy": {
    "startCommand": "cd server && node src/index.js",
    "healthcheckPath": "/health",
    "startupCommand": "cd server && node src/index.js"
  }
}
